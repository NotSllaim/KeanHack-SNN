# Server
PORT=5000
CLIENT_ORIGIN=http://localhost:5173
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/lingo?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
AI_DEBUG=false

# Google Gemini / Gemma
GEMMA_API_KEY=replace-with-google-ai-api-key
GEMMA_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-3-flash-preview:generateContent
GEMMA_MODEL=gemini-3-flash-preview
GEMINI_THINKING_BUDGET=0

# ElevenLabs
ELEVENLABS_API_KEY=replace-with-elevenlabs-api-key
ELEVENLABS_TTS_VOICE_ID=replace-with-elevenlabs-voice-id
ELEVENLABS_TTS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_STT_MODEL_ID=scribe_v1
DEEPGRAM_API_KEY=replace-with-deepgram-api-key
DEEPGRAM_TTS_MODEL_ID=aura-2-arcas-en
DEEPGRAM_TTS_SANA_MODEL_ID=aura-2-athena-en
DEEPGRAM_TTS_THEO_MODEL_ID=aura-2-orpheus-en
DEEPGRAM_TTS_JAX_MODEL_ID=aura-2-apollo-en
DEEPGRAM_TTS_MIRA_MODEL_ID=aura-2-vesta-en

# Client
VITE_API_URL=http://localhost:5000/api

# Solana (devnet RPC for the Upgrade screen; falls back to public devnet if blank)
VITE_HELIUS_DEVNET_RPC=
# Destination wallet that receives USDC payments
VITE_MERCHANT_WALLET=
# USDC mint on Solana devnet (Circle's devnet faucet mint)
VITE_USDC_MINT_DEVNET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# Subscription price in USDC (e.g. 0.1)
VITE_SUBSCRIPTION_PRICE_USDC=0.1

